# Portfolio Backend (loaded via env_file in docker-compose.yml)
# Copy this file to .env and fill in real values

# E-Commerce Database
MYSQL_DATABASE=full-stack-ecommerce
MYSQL_USER=ecommerceapp
MYSQL_PASSWORD=CHANGEME_ecommerce_password
MYSQL_ROOT_PASSWORD=CHANGEME_root_password

# E-Commerce Backend
ECOMMERCE_MYSQL_URL=jdbc:mysql://ecommerce-db:3306/full-stack-ecommerce?useSSL=false&useUnicode=yes&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&serverTimezone=UTC
ECOMMERCE_MYSQL_USERNAME=ecommerceapp
ECOMMERCE_MYSQL_PASSWORD=CHANGEME_ecommerce_password
ECOMMERCE_JWT_SECRET=CHANGEME_generate_a_64_char_hex_secret

# ATS Database
POSTGRES_DB=ats
POSTGRES_USER=atsapp
POSTGRES_PASSWORD=CHANGEME_ats_password

# ATS Backend
ATS_POSTGRES_URL=jdbc:postgresql://ats-db:5432/ats
ATS_POSTGRES_USERNAME=atsapp
ATS_POSTGRES_PASSWORD=CHANGEME_ats_password
